# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
# Optional. If set, swarm agents whose registry entry uses provider="openai"
# will use it. Falls back to Gemini if missing.
OPENAI_API_KEY=
ENCODIAN_API_KEY=
APP_URL=http://localhost:3000

# --- Swarm orchestration limits (all optional, with safe defaults) ---
# Maximum total agents (including the coordinator) per /api/ai runSwarm request.
SWARM_MAX_AGENTS=8
# Maximum spawn depth (coordinator is depth 0).
SWARM_MAX_DEPTH=2
# Maximum cumulative input+output tokens across all agents in one run.
SWARM_MAX_TOKENS=120000
# Maximum wall-clock milliseconds for a single runSwarm request.
SWARM_MAX_WALL_MS=90000
# Maximum agent "turns" (LLM calls) for one agent before it is forced to finish.
SWARM_MAX_TURNS_PER_AGENT=6
